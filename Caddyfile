# Caddy — reverse proxy + HTTPS automatique (Let's Encrypt) pour Alia.
# Nécessite : DNS alia.stellrstudio.fr -> IP du VPS, et ports 80/443 ouverts.

{
	email quentin.bourdin@stellrstudio.fr
}

alia.stellrstudio.fr {
	encode zstd gzip
	reverse_proxy app:3000

	# En-têtes de sécurité de base.
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
	}
}
