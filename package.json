{
  "name": "alia",
  "version": "0.1.0",
  "private": true,
  "description": "Alia — application de coaching en image (espace cliente, dashboard coach, pages publiques).",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "seed:demo": "node --conditions=react-server --env-file-if-exists=.env.local --import tsx scripts/seed-demo-passwords.ts",
    "demo:smoke": "node --conditions=react-server --env-file-if-exists=.env.local --import tsx scripts/demo-smoke.ts",
    "demo:smoke:p1": "node --conditions=react-server --env-file-if-exists=.env.local --import tsx scripts/demo-smoke-p1.ts",
    "demo:smoke:p234": "node --conditions=react-server --env-file-if-exists=.env.local --import tsx scripts/demo-smoke-p234.ts",
    "demo:smoke:public": "node --conditions=react-server --env-file-if-exists=.env.local --import tsx scripts/demo-smoke-public.ts",
    "demo:smoke:coach": "node --conditions=react-server --env-file-if-exists=.env.local --import tsx scripts/demo-smoke-coach.ts",
    "test": "node --conditions=react-server --env-file-if-exists=.env.local --import tsx --test tests/*.test.ts"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.4",
    "bcryptjs": "^2.4.3",
    "clsx": "^2.1.1",
    "jose": "^5.9.6",
    "next": "^15.1.6",
    "nodemailer": "^6.10.1",
    "postgres": "^3.4.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "server-only": "^0.0.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.10.5",
    "@types/nodemailer": "^6.4.24",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.5.1",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
