# Copier en .env et adapter. Utilisé par docker-compose.yml.
# (Le .env réel n'est PAS versionné — cf. .gitignore.)

POSTGRES_USER=image_coaching
POSTGRES_PASSWORD=image_coaching
POSTGRES_DB=image_coaching
# Port HÔTE exposé par le conteneur (5433 pour éviter un conflit avec un
# PostgreSQL local sur 5432).
POSTGRES_PORT=5433
