# =====================================================================
# Alia — variables d'environnement (modèle). Copier en `.env.local`.
# JAMAIS de vraie valeur secrète dans ce fichier ni dans le code.
# =====================================================================

# --- Base de données (privilégiée : app + coach) ---------------------
# En dev local (PostgreSQL Homebrew, auth trust) :
DATABASE_URL=postgresql://quentin@localhost:5432/image_coaching
# En prod (Docker / IONOS), ex. :
# DATABASE_URL=postgresql://image_coaching:motdepasse@db:5432/image_coaching

# --- Seam PUBLIC (isolation PII) -------------------------------------
# Connexion à privilèges réduits utilisée UNIQUEMENT par les routes
# publiques (lecture de la vue public_availability, réservation).
# En prod : créer un rôle `app_anon` (cf. README, section déploiement)
# et pointer cette URL dessus. En dev, laisser vide => retombe sur
# DATABASE_URL.
DATABASE_URL_PUBLIC=

# --- Sessions (JWT signé, cookie httpOnly) ---------------------------
# Secret de signature des sessions. Générer avec : openssl rand -hex 32
SESSION_SECRET=remplacer_par_un_secret_de_32_octets_minimum_en_hex

# --- URL publique de l'application -----------------------------------
APP_URL=http://localhost:3000
# En prod : https://alia.stellrstudio.fr

# --- IA Mistral (serveur uniquement, Phase 3) ------------------------
MISTRAL_API_KEY=

# --- Stockage objet IONOS S3 (Phase 3/5) -----------------------------
# En dev, laisser S3_* vide => l'adaptateur disque local est utilisé.
S3_ENDPOINT=
S3_REGION=eu-central-1
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=

# --- Emails transactionnels (Phase 2) --------------------------------
# En dev, laisser vide => les emails sont écrits dans la console.
EMAIL_FROM=Alia <bonjour@alia.stellrstudio.fr>
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=
EMAIL_SMTP_PASSWORD=
